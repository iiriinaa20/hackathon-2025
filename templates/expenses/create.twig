{% extends 'layout.twig' %}
{% block title %}Add Expense{% endblock %}
{% block content %}
<h1 class="text-2xl font-bold mb-4">Add Expense</h1>

<section class="mb-8">
  <form action="/expenses" method="POST" class="max-w-sm mx-auto">

    <div class="mb-4">
      <label for="date" class="block text-gray-300 font-bold mb-1">Date:</label>
      <input type="date" id="date" name="date" required
             value="{{ old.date|default(('now'|date('Y-m-d'))) }}"
             class="w-full shadow appearance-none border rounded py-2 px-3 bg-gray-700 text-gray-100 leading-tight focus:outline-none focus:shadow-outline" />
      {% if errors.date is defined %}
        <span class="text-red-500 text-sm">{{ errors.date }}</span>
      {% endif %}
    </div>

    <div class="mb-4">
      <label for="category" class="block text-gray-300 font-bold mb-1">Category:</label>
      <select id="category" name="category" required
              class="w-full shadow appearance-none border rounded py-2 px-3 bg-gray-700 text-gray-100 leading-tight focus:outline-none focus:shadow-outline">
        <option value="">Select a category</option>
        {% for category in categories %}
          <option value="{{ category }}"
            {% if old.category is defined and old.category == category %}selected{% endif %}>
            {{ category }}
          </option>
        {% endfor %}
      </select>
      {% if errors.category is defined %}
        <span class="text-red-500 text-sm">{{ errors.category }}</span>
      {% endif %}
    </div>

    <div class="mb-4">
      <label for="amount" class="block text-gray-300 font-bold mb-1">Amount:</label>
      <input type="number" step="0.01" id="amount" name="amount" required
             value="{{ old.amount|default('') }}"
             class="w-full shadow appearance-none border rounded py-2 px-3 bg-gray-700 text-gray-100 leading-tight focus:outline-none focus:shadow-outline" />
      {% if errors.amount is defined %}
        <span class="text-red-500 text-sm">{{ errors.amount }}</span>
      {% endif %}
    </div>

    <div class="mb-6">
      <label for="description" class="block text-gray-300 font-bold mb-1">Description:</label>
      <textarea id="description" name="description" rows="2"
                class="w-full shadow appearance-none border rounded py-2 px-3 bg-gray-700 text-gray-100 leading-tight focus:outline-none focus:shadow-outline">{{ old.description|default('') }}</textarea>
      {% if errors.description is defined %}
        <span class="text-red-500 text-sm">{{ errors.description }}</span>
      {% endif %}
    </div>

    <div class="flex justify-end">
      <button type="submit"
              class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline">
        Create
      </button>
    </div>
  </form>
</section>
{% endblock %}